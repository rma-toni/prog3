{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Ejecutar y Limpiar",
            "type": "shell",
            "command": "g++ ${file} -o ${fileBasenameNoExtension} && ./${fileBasenameNoExtension} && rm ${fileBasenameNoExtension}",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        }
    ]
}